# IntelBot-PWA environment variables. Copy to .env.local (gitignored) for dev,
# or set in Vercel project settings for production.

# --- Model provider API keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=

# --- Vault location (local dev). In production the vault comes from SharePoint
#     (below); when SHAREPOINT_* is set, VAULT_PATH is ignored. ---
VAULT_PATH=

# --- SharePoint vault sync (Microsoft Graph, app-only) ---
# When set, IntelBot mirrors a SharePoint document-library folder into a local
# dir and indexes that. This is how the Obsidian vault reaches production: Mike
# edits in Obsidian → OneDrive client syncs to SharePoint → server pulls it down.
# Uses the SAME Entra app as auth above, but that app must be granted *application*
# Graph permission Sites.Selected (preferred, scoped to the IntelBot site) or
# Sites.ReadWrite.All. See docs/deployment-and-security-plan.md for the click-path.
#
# Provide the tenant (or it's derived from AUTH_..._ISSUER) and ONE of SITE_ID /
# SITE_PATH. Leave the whole block blank for local-vault dev (no regression).
SHAREPOINT_TENANT_ID=              # optional; falls back to tenant in AUTH_..._ISSUER
SHAREPOINT_SITE_PATH=nreagency.sharepoint.com:/sites/uRentTeam   # the UPE Team site
SHAREPOINT_SITE_ID=                # alternative to SITE_PATH: full Graph site id
SHAREPOINT_DRIVE_NAME=             # optional; default = the "Documents" library
SHAREPOINT_VAULT_FOLDER=CEO Intelbot                            # the synced vault folder
SHAREPOINT_SAVE_FOLDER=CEO Intelbot/Bot Answers                 # where saved answers land (auto-created)
SHAREPOINT_SYNC_DIR=               # local mirror dir (default .vaultcache/sharepoint; use a persistent volume in prod)

# Shared secret so a scheduler can trigger POST /api/sync unattended:
#   curl -X POST https://<host>/api/sync -H "Authorization: Bearer <SYNC_SECRET>"
SYNC_SECRET=

# --- Audit log ---
# Append-only, tamper-evident Q&A log (questions hashed, answers in clear).
# Defaults under .vaultcache/audit; point at the persistent volume in prod.
AUDIT_DIR=

# --- Authentication: Microsoft 365 SSO (Microsoft Entra ID) ---
# Auth is ENFORCED only when AUTH_MICROSOFT_ENTRA_ID_ID is set. Leave blank for
# open local dev. Set ALL of these in production (Vercel) to lock the app down.
AUTH_SECRET=                       # random string: run `npx auth secret`
AUTH_URL=                          # e.g. https://intelbot.yourdomain.com (prod) / http://localhost:3000 (dev)
AUTH_MICROSOFT_ENTRA_ID_ID=        # Entra "Application (client) ID"
AUTH_MICROSOFT_ENTRA_ID_SECRET=    # Entra client secret VALUE
AUTH_MICROSOFT_ENTRA_ID_ISSUER=    # https://login.microsoftonline.com/<tenant-id>/v2.0

# Allowlist of emails permitted to sign in (comma-separated). Empty = any user
# in the tenant. Set to Mike's account (+ a break-glass admin).
INTELBOT_ALLOWED_EMAILS=

# --- Optional model overrides (defaults in lib/registry.ts) ---
# ANTHROPIC_MODEL=
# OPENAI_MODEL=
# PERPLEXITY_MODEL=
# MAX_OUTPUT_TOKENS=
